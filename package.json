{
	"name": "event-game-platform",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "eslint .",
		"deploy": "opennextjs-cloudflare build && wrangler deploy",
		"upload": "opennextjs-cloudflare build && wrangler deploy --dry-run",
		"preview": "opennextjs-cloudflare build && wrangler dev",
		"test:smoke": "node scripts/smoke-preview.mjs",
		"test:load": "node scripts/load-test-preview.mjs",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.9",
		"next": "16.2.6",
		"qrcode": "^1.5.4",
		"react": "^19.1.7",
		"react-dom": "^19.1.7"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.103.0"
	}
}
